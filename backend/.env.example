# Copy to .env and fill in real values.
ENVIRONMENT=development

# Long random string. Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Local dev uses SQLite by default (leave as-is). For Postgres:
# DATABASE_URL=postgresql://user:password@localhost:5432/medpredict
DATABASE_URL=sqlite:///./local.db

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# First admin, auto-created on first startup.
FIRST_ADMIN_EMAIL=admin@medpredict.local
FIRST_ADMIN_PASSWORD=Admin@12345
FIRST_ADMIN_NAME=Super Admin

# Path to the cutoff dataset (defaults to ../data/All_Medical_College_Last_Cutoff.xlsx)
# DATASET_PATH=/absolute/path/to/dataset.xlsx
DATASET_SHEET=All Colleges
